powerlifting:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project: "{{ env_var('BQ_PROJECT', env_var('GCP_PROJECT_ID', 'your-gcp-project-id')) }}"
      dataset: "{{ env_var('BQ_DATASET', 'powerlifting') }}"
      location: US
      keyfile: "{{ env_var('GOOGLE_APPLICATION_CREDENTIALS', '/absolute/path/to/service-account-key.json') }}"
      threads: 4
      timeout_seconds: 300
