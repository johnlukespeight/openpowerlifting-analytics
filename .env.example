# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# GCS bucket names (must match Terraform outputs)
GCS_RAW_BUCKET=your-gcp-project-id-opl-raw
GCS_PROCESSED_BUCKET=your-gcp-project-id-opl-processed

# Path to your GCP service account JSON key (downloaded after terraform apply)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json

# BigQuery
BQ_DATASET=powerlifting
BQ_PROJECT=your-gcp-project-id
