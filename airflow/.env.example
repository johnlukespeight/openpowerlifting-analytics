# Copy this file to airflow/.env before running `docker compose up`.

GCP_PROJECT_ID=your-gcp-project-id
GCS_RAW_BUCKET=your-gcp-project-id-opl-raw
GCS_PROCESSED_BUCKET=your-gcp-project-id-opl-processed

# Absolute path on your machine to the GCP service account key JSON.
AIRFLOW_GCP_KEY_PATH=/absolute/path/to/service-account-key.json
